{
  "folders": [
    {
      "name": "🚀 Bootcamp Git & GitHub",
      "path": "."
    }
  ],
  "settings": {
    // ═══════════════════════════════════════════════════════════════════════
    // PEACOCK - Color naranja de Git (#F05032)
    // ═══════════════════════════════════════════════════════════════════════
    "peacock.color": "#F05032",
    "peacock.remoteColor": "#FF6F47",
    
    // ═══════════════════════════════════════════════════════════════════════
    // OPTIMIZACIÓN DE RECURSOS - Solo una pestaña activa
    // ═══════════════════════════════════════════════════════════════════════
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 1,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.showTabs": "single",
    "workbench.editor.wrapTabs": false,
    "workbench.editor.scrollToSwitchTabs": false,
    "workbench.editor.revealIfOpen": true,
    "workbench.editor.focusRecentEditorAfterClose": true,
    "workbench.editor.closeEmptyGroups": true,
    "workbench.editor.closeOnFileDelete": true,
    
    // ═══════════════════════════════════════════════════════════════════════
    // COLORES PERSONALIZADOS - Tema Git/GitHub
    // ═══════════════════════════════════════════════════════════════════════
    "workbench.colorCustomizations": {
      "titleBar.activeBackground": "#F05032",
      "titleBar.activeForeground": "#ffffff",
      "titleBar.inactiveBackground": "#F0503299",
      "titleBar.inactiveForeground": "#ffffff99",
      "statusBar.background": "#F05032",
      "statusBar.foreground": "#ffffff",
      "statusBar.debuggingBackground": "#FF6F47",
      "statusBar.debuggingForeground": "#ffffff",
      "statusBar.noFolderBackground": "#F05032",
      "statusBar.noFolderForeground": "#ffffff",
      "activityBar.background": "#F05032",
      "activityBar.foreground": "#ffffff",
      "activityBar.inactiveForeground": "#ffffff99",
      "activityBarBadge.background": "#238636",
      "activityBarBadge.foreground": "#ffffff",
      "panel.border": "#F05032",
      "sideBar.border": "#F05032",
      "editorGroup.border": "#F05032",
      "tab.activeBorder": "#F05032",
      "tab.activeModifiedBorder": "#238636",
      "editorGroupHeader.tabsBackground": "#0d1117"
    }
  },
  "extensions": {
    "recommendations": [
      "johnpapa.vscode-peacock",
      "ms-vscode.vscode-git",
      "eamodio.gitlens",
      "github.vscode-pull-request-github",
      "github.copilot",
      "github.copilot-chat",
      "davidanson.vscode-markdownlint",
      "yzhang.markdown-all-in-one",
      "shd101wyy.markdown-preview-enhanced"
    ]
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#f37962",
    "activityBar.background": "#f37962",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#89f69a",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#f37962",
    "statusBar.background": "#f05033",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#f37962",
    "statusBarItem.remoteBackground": "#f05033",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#f05033",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#f0503399",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#f05033"
}
